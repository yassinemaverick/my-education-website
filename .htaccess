# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prevent directory listing & set homepage
Options -Indexes
DirectoryIndex index.php

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://study.upskill-edu.com; frame-ancestors 'none';"
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Canonical clean URLs for language pages
RewriteCond %{THE_REQUEST} \ /index-en\.php [NC]
RewriteRule ^ /en [R=301,L]

RewriteCond %{THE_REQUEST} \ /index-fr\.php [NC]
RewriteRule ^ /fr [R=301,L]

# Redirect other .php URLs to clean versions (skip dispatcher, lang pages & API endpoints)
RewriteCond %{THE_REQUEST} \ /([^/]+)\.php [NC]
RewriteCond %1 !^index(-en|-fr)?$ [NC]
RewriteCond %1 !^enroll$ [NC]
RewriteCond %1 !^contact$ [NC]
RewriteRule ^ /%1 [NC,R=301,L]

# Serve .php files for clean URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Clean language URL routing
RewriteRule ^en$ /index-en.php [L]
RewriteRule ^fr$ /index-fr.php [L]